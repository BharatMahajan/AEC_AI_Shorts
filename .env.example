# ── Copy this file to .env and fill in. In GitHub, add each as a repo Secret. ──
# .env is gitignored and must NEVER be committed.

# Google Gemini (FREE tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key

# YouTube Data API v3 OAuth (see FIRST_RUN.md "YouTube setup")
YT_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
YT_CLIENT_SECRET=GOCSPX-xxxxxxxx
YT_REFRESH_TOKEN=1//xxxxxxxx

# Optional: read-only API key for L0 analytics (view counts)
YT_DATA_API_KEY=
# Optional: Slack incoming webhook for failure alerts
SLACK_WEBHOOK_URL=

# ── Behaviour toggles ──
# public | unlisted | private  (used only when REVIEW_BEFORE_PUBLISH=false)
YT_PRIVACY=public
# true = upload as a private draft and stop (manual SME review). false = fully automatic.
REVIEW_BEFORE_PUBLISH=false
# true = bias next topics by past view counts (needs YT_DATA_API_KEY + history)
ENABLE_ANALYTICS=false
